programa
{
	
	funcao inicio()
	{
		inteiro numero

		escreva("digite seu numero para validarmos: ")
		leia(numero)

		se(numero % 2 == 0)
			escreva("numero par\n")
		senao
			escreva("numero impar\n")
	}
}

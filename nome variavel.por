programa
{
	
	funcao inicio()
	{
		real a, b, soma, sub, mult, div

		escreva("digite o primeiro numero: ")
		leia(a)

		escreva("digite o segundo numero: ")
		leia(b)


		soma = a + b
		escreva("\na soma de a + b é: ", soma, "\n")
		
		sub = a - b
		escreva("a subtração de a - b é: ", sub, "\n")
		
		mult = a * b
		escreva("a multiplicação de a * b é: ", mult, "\n")
		
		div = a / b
		escreva("a divisão de a + b é: ", div, "\n")
	
	}
}
